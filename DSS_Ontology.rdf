    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#StakeholderPanel -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#StakeholderPanel">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#StakeholderPanel"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <owl:definition>A participatory process that brings together representatives of different stakeholder groups to provide input, share perspectives, and contribute to decision-making, evaluation, or model development over an extended period.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Statistics -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Statistics">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Statistics"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>A method of uncertainty evaluation based on statistical analysis and inference, used to quantify variability, estimate parameters, test hypotheses, or assess the reliability of data and model outputs.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Survey -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Survey">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Survey"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <owl:definition>A participatory process used to collect information, opinions, or feedback from individuals or stakeholder groups through structured questionnaires or interviews, either in person or via digital platforms.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUser -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUser">
