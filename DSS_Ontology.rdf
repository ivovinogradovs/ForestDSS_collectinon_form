        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#uses"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DataOutput"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>The entity provides outputs with uncertainty estimates or supports uncertainty analysis.</owl:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#assessesNaturalDisturbances -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#assessesNaturalDisturbances">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAccessability -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAccessability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>commercial</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>licensed</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>open-source</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>restricted</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Describes the level or type of access available for a software tool, model, or dataset, such as whether it is open-source, freely available, restricted, or commercial.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAcronym -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAcronym">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasName"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>A short, abbreviated form of a name or phrase that represents a decision support system.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAffiliation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasAffiliation">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Associates an individual, organization, or entity with the group, institution, network, or organizational unit to which it formally belongs or is connected.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasApplicationYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasApplicationYear">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <owl:definition>Year of the last known utilisation of the software in real life problems.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasBeneficiaryType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasBeneficiaryType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Indicates who benefits from the forest ecosystem service.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasBiomeOrEcoregion -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasBiomeOrEcoregion">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the biome or ecoregion associated with the data, application, or study context of a software tool or system (e.g., tropical rainforest, tundra, marine, freshwater, desert).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCollectionMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCollectionMethod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the method, procedure, or technique used to collect data, samples, observations, or information.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCopyright -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCopyright">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the copyright status, rights holder, or licensing conditions that apply to a resource.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCosts -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCosts">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <owl:definition>Estimated total cost for a typical user to deploy and operate the Software. Includes software acquisition or licensing fees, necessary hardware or software setup, installation, and potential costs for specialist assistance. Costs are expressed for an average computing environment suitable for the target user group.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCountry -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the country or countries in which a software tool, model, dataset, or participatory process is developed, applied, or relevant.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDataSource -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDataSource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#InputData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the data source of the input data: 
Remote sensing: Data obtained from remote sensing. 
Field survey: Data collected directly in the field through observation or measurement. Administrative: Data sourced from official records or statistics. 
Modelling: Data generated from simulation or predictive models. 
Literature: Data derived from published sources or scientific studies.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDataType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDataType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the type or nature of data used, produced, or managed by a software tool, model, or dataset (e.g., spatial data, time series, tabular data, raster, vector, or textual data).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDatabaseManagementSystem -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDatabaseManagementSystem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Access</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>DB2</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Excel</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Informix</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>MariaDB</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>MongoDB</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>MySQL</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>Neo4j</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>NoSQL</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>None</rdf:first>
                                                                                                <rdf:rest>
                                                                                                    <rdf:Description>
                                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                        <rdf:first>Oracle</rdf:first>
                                                                                                        <rdf:rest>
                                                                                                            <rdf:Description>
                                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                <rdf:first>Other</rdf:first>
                                                                                                                <rdf:rest>
                                                                                                                    <rdf:Description>
                                                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                        <rdf:first>PostgreSQL</rdf:first>
                                                                                                                        <rdf:rest>
                                                                                                                            <rdf:Description>
                                                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                                <rdf:first>SQLite</rdf:first>
                                                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                                                            </rdf:Description>
                                                                                                                        </rdf:rest>
                                                                                                                    </rdf:Description>
                                                                                                                </rdf:rest>
                                                                                                            </rdf:Description>
                                                                                                        </rdf:rest>
                                                                                                    </rdf:Description>
                                                                                                </rdf:rest>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the database management system (DBMS) or data storage platform used or supported by a software tool, system, or application.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDecisionMakingSituation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDecisionMakingSituation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>collegial (many DM)</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>multiple objectives</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>participatory (many DM)</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>single objectives</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>unilateral (one DM)</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Provides details about the decision making situation of the planning problem: 
unilateral (one DM): one decison maker decides without consultation of others. participatory (many DM): many decision makers negotiate for the best solution, many opinions, voices, perceptions are heard, but there is no consensus needed among the parties, in most cases the majority decides. 
collegial (many DM): many decision makers negotiate for the best solution, consensus is needed among the parties. 
single objectives: The management planning problem addresses one and just one objective. 
multiple objectives: The management planning problem addresses two or more objectives, any pairs of which could be conflicting, complementary or neutral with respect to their contributions</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDecisionStage -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDecisionStage">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Specifies which phase or stage of a decision process an entity is associated with (e.g., Regulatory, Advisory, Operational, Technical, Financial, Mixed, None)</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDescription -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>A textual description that provides additional human-readable information about a  concept or individual.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDesignMethodology -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDesignMethodology">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the main design approach, framework, or methodological reference applied during the design phase of the IT solution or software project (e.g., software engineering, user-centered design, agile development).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDeveloperCount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDeveloperCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <owl:definition>Specifies the number of people in the developer team (people, with at least 10% involvement of the project)</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDevelopmentManagement -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDevelopmentManagement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Describes the software development and project management methodology applied during the software development and maintenance. This includes agile frameworks (e.g. Scrum, Kanban, XP) or other structured approaches defining how tasks, iterations, and releases are organized.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEducationalApplication -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEducationalApplication">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Specifies whether the software is used in education.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEmail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEmail">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the email address associated with an individual, organization, or contact entity.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEmergentProperty -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEmergentProperty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Specifies whether the natural distrubance model represents natural disturbances as emergent properties from other processes.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEngagementPurpose -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEngagementPurpose">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the main purpose or objective of stakeholder or participant engagement within a participatory process, such as information sharing, consultation, co-design, decision-making, or evaluation.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEvaluationMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasEvaluationMethod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the type of evaluation of the participatory processes applied (e.g., feedback forms, follow-up interviews).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFacilitationLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFacilitationLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>external</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>internal</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>none</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Indicates whether a process, activity, or interaction is supported by facilitation carried out internally, externally, or not facilitated at all.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFormat -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFormat">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first> PDF</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Excel</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>GeoJSON</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>GeoTIFF</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>csv</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>geodatabase</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>netCDF</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>other</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>shapefile</rdf:first>
                                                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the digital file format used or supported by a software tool, model, or dataset (e.g., CSV, NetCDF, GeoTIFF, JSON, XML, or shapefile).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFundingSource -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFundingSource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Identifies the organization, program, institution, or entity that provides financial support for a project, activity, resource, or initiative.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasGISIntegration -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasGISIntegration">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether the software tool or system includes, supports, or integrates Geographic Information System (GIS) functionality.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHardwareRequirements -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHardwareRequirements">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the physical computing resources required for the software to function, such as processing capacity, memory, storage, or specialized hardware.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingOperation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingOperation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>extraction</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>felling</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>processing</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the type of harvesting operations represented or supported by the software tool, model, or system</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingSystem -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingSystem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>animal logging</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>cable logging</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>ground-based logging</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>helicopter logging</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>others</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the harvesting system represented or supported by the software tool, model, or system.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasHarvestingType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>machine</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>manual</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>mixed</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the type or method of harvesting represented or supported by the software tool, model, or system.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITDocumentation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITDocumentation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether the DSS provides documentation describing its source code.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITDocumentationURL -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITDocumentationURL">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <owl:definition>Reference or link to the source code documentation.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITToolType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasITToolType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>GUI</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>command line</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>desktop</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>extension (based on standard software)</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>mobile device app</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>other</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>web</rdf:first>
                                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the type or deployment form of an information technology (IT) tool, such as whether it is a command-line program, graphical application, web-based service, or other type of software implementation.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasIndicatorType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasIndicatorType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DataOutput"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#InputData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the category or nature of an indicator produced, used, or represented by a software tool, model, or dataset (e.g., categorial, numeric, index, map).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasInfrastructureManagement -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasInfrastructureManagement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the types of management operations that the forest management involves (e.g., road network, skid trails, processing yards, others).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasInitiator -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasInitiator">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the person, organization, or group that initiated or launched the development of a software tool, model, project, or participatory process.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLatitude -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLatitude">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <owl:definition>Specifies the north–south geographic coordinate of a location, expressed as a numerical value in decimal degrees.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLessonStatement -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLessonStatement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Provides details of the specific lesson learned, the why and the how</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLicense -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLicense">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the licence or usage rights under which a resource is distributed, accessed, or reused.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLocation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLocation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Associates an entity with a spatial feature, place, or geographic position where it exists, occurs, or is relevant.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLongitude -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasLongitude">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <owl:definition>Specifies the east–west geographic coordinate of a location, expressed in decimal degrees.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasManagementScale -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasManagementScale">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range>
            <rdfs:Datatype>
