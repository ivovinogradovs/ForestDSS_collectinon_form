    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MarkovChain -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MarkovChain">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MarkovChain"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>A stochastic modeling approach used in uncertainty evaluation that represents systems as a sequence of states with probabilistic transitions, allowing the analysis of dynamic processes and their uncertainty over time.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MixedIntegerProgramming -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MixedIntegerProgramming">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiObjectiveDecisionSupportMethod"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MonteCarloSimulation -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MonteCarloSimulation">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MonteCarloSimulation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>A method of uncertainty evaluation that uses random sampling and statistical simulation to estimate the variability or probability distribution of outcomes in a model or system.</owl:definition>
    </owl:Axiom>
    


