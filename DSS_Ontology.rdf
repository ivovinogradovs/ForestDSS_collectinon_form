    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasProvider -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasProvider">
