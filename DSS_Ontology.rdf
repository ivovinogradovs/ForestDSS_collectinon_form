    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ExpertSystem -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ExpertSystem">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ExpertSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
        <owl:definition>Expert systems (or Knowledge-based system) are designed in such a way that a rulebase and an inference engine are interlinked to simulate the reasoning process that a human expert pursues in analyzing a problem and arriving at a conclusion. In these systems a vast amount of knowledge is stored in the knowledge base. The knowledge base could consist of &quot;if then&quot; statements that resemble the sequence of mental steps that are involved in the human reasoning process.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FocusGroup -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FocusGroup">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FocusGroup"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <owl:definition>A participatory process that gathers a small group of stakeholders or participants to discuss specific topics, experiences, or opinions in a guided setting, typically to explore perceptions, attitudes, or needs related to a project, tool, or decision context.</owl:definition>
    </owl:Axiom>
    


