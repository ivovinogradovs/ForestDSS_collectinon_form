        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the organization, institution, or individual responsible for providing, maintaining, or distributing a software tool, service, or dataset.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasRealLifeApplication -->

