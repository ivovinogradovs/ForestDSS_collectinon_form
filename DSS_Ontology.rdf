    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasScenarioType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasScenarioType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Scenario"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>indicates the types of scenarios an entity represents or is associated with, based on the characteristics, purpose, or structure of that scenario (e.g., climate scenario, landuse scenario)</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasScientificReference -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasScientificReference">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>References to scientific publications, datasets, or other scholarly sources that support or relate to the resource.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSoftwareRequirements -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSoftwareRequirements">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the software components, platforms, libraries, or system environments required for the software to operate correctly.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSource -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Identifies the origin, reference, or provenance from which information, data, content, or a resource is derived.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialContext -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialContext">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Non spatial</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Spatial with neighborhood interrelations</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Spatial with no neighborhood interrelations</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>Specifies the type of spatial involvement of an entity, distinguishing whether it possesses spatial characteristics and whether those characteristics interact through neighborhood relations.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialExtent -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialExtent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Describes the geographic area or spatial coverage to which a software tool, model, or dataset applies or for which it provides results (e.g., local, regional, national, continental, or global extent).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialResolution -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialResolution">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the spatial resolution or level of spatial detail at which the software tool, model, or dataset operates or produces outputs (e.g., 10 m, 1 km, regional, or global scale).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialScale -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpatialScale">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#GrowthModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MortalityModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#RegenerationModel"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>&gt;landscape</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>cohort</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>landscape</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>stand</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>tree</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Specifies the spatial scale at which vegetation dynamics are modelled.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpecies -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasSpecies">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#HabitatModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WildlifeModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the species that can be represented</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnicalDocumentation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnicalDocumentation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether the DSS has a technical documentation conceptually describing the DSS&apos;s purpose, supported processes, underlying architecture, algorithms, and key equations.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnicalDocumentationURL -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnicalDocumentationURL">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <owl:definition>Reference or link to the technical documentation of the DSS.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnologyReadiness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTechnologyReadiness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>commercial product</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>non-commercial product</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>open-source product</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>other</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>prototype with no practical application</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>prototype with practical application</rdf:first>
                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Indicates the level of technological maturity or development stage of a software tool or system, such as whether it exists as a prototype, open-source, or commercial product.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalCoverageEnd -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalCoverageEnd">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <owl:definition>Specifies the ending date or time point of the temporal period covered by a software tool, model, problem, case study, or dataset (e.g., the last year or date represented in the data or simulation).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalCoverageStart -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalCoverageStart">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <owl:definition>Specifies the starting date or time point of the temporal period covered by a software tool, model, problem, case study, or dataset (e.g., the first year or date represented in the data or simulation).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalResolution -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalResolution">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the temporal resolution or time step at which the software tool, model, or dataset operates or produces outputs (e.g., hourly, daily, monthly, yearly, decadal).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalStructure -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTemporalStructure">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>continuous</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>iterative</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>one-time</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <owl:definition>Describes the temporal organization or duration pattern of a participatory process, project, or modeling activity — specifically whether it is conducted as a one-time event, an iterative series, or a continuous ongoing process.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTreeSpecies -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasTreeSpecies">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the tree species or group of species that are represented, analyzed, or managed by the software tool, model, or dataset (e.g., Pinus sylvestris, Picea abies, mixed broadleaf species).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasURL -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasURL">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <owl:definition>Web address or online reference associated with a resource, organization, person, or service.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUncertaintyMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUncertaintyMethod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the method, technique, or approach used by the software tool or model to represent, quantify, or analyze uncertainty.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUnit -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUnit">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the unit of measurement associated with a quantitative value, parameter, or output produced or used by the software tool, model, or dataset (e.g., meters, kilograms, degrees Celsius, hectares, or percent).</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUpdateYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUpdateYear">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <owl:definition>Year of the last update (minor development, maintaining the tool up-todate to the underlying software / OS, fix errors) of the tool.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUpgradeYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUpgradeYear">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <owl:definition>Year of the last upgrade (major development, new functionalities, new version) of the tool.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUserManual -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUserManual">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether the DSS has a user manual describing how to operate the DSS.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUserManualURL -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasUserManualURL">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <owl:definition>Reference or link to the user manual describing how to operate the DSS.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasVersion -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasVersion">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the version identifier of a resource, model, dataset, document, software component, or any entity that exists in multiple revisions.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasVisualization -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasVisualization">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether a tool or system provides visualization capabilities, such as charts, maps, dashboards, or other graphical representations of data or results.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasWaterBalanceModule -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasWaterBalanceModule">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SoilProcessesModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether the software tool, model, or system includes a component or functionality that represents or simulates water balance processes, such as precipitation, evapotranspiration, runoff, or infiltration.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isClimateSensitive -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isClimateSensitive">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Speficies whether the model of vegetation dynamics responds to climate variation in at least in one of its processes.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isDeterministic -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isDeterministic">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isSpatiallyExplicit -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#isSpatiallyExplicit">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#HabitatModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SoilProcessesModel"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WildlifeModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresOperatingSystem -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresOperatingSystem">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Android</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Linux</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Other</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Unix</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>Web-based</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>Windows</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>iOS</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>macOS</rdf:first>
                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresSkills -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresSkills">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies a skill, competence, or area of expertise that a user must possess to effectively use a software tool, system, or service.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresTrainingTime -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#requiresTrainingTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <owl:definition>Indicates the estimated amount of time in hours thta a skilled user needs to be trained in order to effectively use a software tool, system, or service.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemModeling -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemModeling">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether a software tool, model, or decision-support system assists users in representing or formalizing a decision problem through conceptual, mathematical, or computational models.

In problem modelling the relations between the different entities of a problem are described in a formal way, which supports then the solving of the problem</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemSolving -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemSolving">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether a software tool, model, or decision-support system assists users in solving a defined problem, such as generating, analyzing, or selecting among alternative solutions based on specified criteria.

In problem solving the best option for solving a problem is found among a set of alternatives or within a given decision space</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemStructuring -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#supportsProblemStructuring">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Indicates whether a software tool, model, or decision-support system assists users in structuring or defining a decision problem, such as identifying objectives, criteria, stakeholders, or relationships among decision elements.

In problem structuring the problem is decomposed to its single entities (objectives and preferences, site and stand characteristics, alternatives, stakeholders,...)</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#usesAI -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#usesAI">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Specififes whether the software uses Artificial Intelligence.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BeetleModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BeetleModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BioticDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Biodiversity -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Biodiversity">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <owl:definition>Describes the benefits associated with the maintenance, enhancement, or support of biological diversity, including the variety of species, habitats, and genetic resources that sustain ecosystem function and resilience.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BioticDisturbanceModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BioticDisturbanceModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CarbonDynamicsModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CarbonDynamicsModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel"/>
        <owl:definition>Simulates carbon fluxes and storage in vegetation, soil, and other pools.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CaseStudy">
        <owl:definition>An empirical application of a DSS in a particular geographical or management context.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CulturalService -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CulturalService">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <owl:definition>Describes non-material benefits that people obtain from ecosystems through experience, emotion, or knowledge — including recreation, aesthetics, and spiritual connections.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data">
        <owl:definition>Structured information used or produced by the DSS.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DataOutput -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DataOutput">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasDataType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFormat"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:definition>The type of data or indicators generated by the DSS as results (e.g., maps, performance indicators, scenario outputs).</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportSystem">
        <owl:definition>A computational or conceptual system that integrates data, models, and analytical or participatory methods to support decision-making in forest management. A DSS typically combines software components, datasets, and decision-support techniques to analyze complex ecological, economic, and social trade-offs.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique">
        <owl:definition>A method, procedure, or analytical approach used within a forest decision support system (DSS) to process information, evaluate alternatives, support reasoning, or enhance decision-making.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DroughtModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DroughtModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EconomicModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EconomicModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SocioEconomicModel"/>
        <owl:definition>An abstract or computational representation of economic systems, behaviors, or relationships used to analyze, explain, or predict economic outcomes.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FireModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FireModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestAdministration -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestAdministration">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Governmental or regulatory bodies responsible for implementing forest policy, enforcing laws, allocating permits, and overseeing forest management.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestConservation -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestConservation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Users or organizations responsible for protecting, restoring, and managing forest ecosystems with the primary goal of maintaining biodiversity, ecological integrity, and long-term sustainability.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestContractor -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestContractor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService">
        <owl:definition>Describes the ecosystem services considered by the DSS, their classification according to standard frameworks (e.g., CICES), and how they are modelled, quantified, and linked to indicators, data sources, and beneficiaries.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEducation -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEducation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Institutions or individuals involved in teaching, training, or disseminating knowledge related to forestry, environmental management, or natural resources.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEngineeringFirm -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEngineeringFirm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Professional service firms specializing in technical planning, engineering solutions, and infrastructural development within forest landscapes (e.g., road design, watershed engineering).</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEnterprise -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEnterprise">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Commercial organizations engaged in the production, processing, or trading of forest goods and services.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestIndustry -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestIndustry">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Industrial actors involved in large-scale processing of forest products such as sawmills, pulp and paper mills, biomass plants, or engineered wood manufacturers.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement">
        <owl:definition>A component of the DSS that represents forest management objectives, strategies, and operational practices. It captures how management actions are defined, structured, and applied.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestOwner -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestOwner">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#GrowthModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#GrowthModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
        <owl:definition>Speficies whether the model of vegetation dynamics represents tree growth dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#HabitatModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#HabitatModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel"/>
        <owl:definition>Represents habitat dynamics (e.g., suitability or quality) for particular species or species groups.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#InputData -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#InputData">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Data"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasFormat"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:definition>The origin of and details on input data used by the DSS.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess">
        <owl:definition>Activities and processes through which knowledge is created, shared, and applied within the DSS framework.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LessonLearned">
        <owl:definition>Insights or conclusions derived from DSS applications or case studies, highlighting successes, limitations, or transferable experiences.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model">
        <owl:definition>A representation of processes implemented within the DSS to simulate or predict system behavior. Models describe ecological, biophysical, or socio-economic processes.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MortalityModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MortalityModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
        <owl:definition>Speficies whether the model of vegetation dynamics represents tree mortality dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiAttributeDecisionSupportMethod -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiAttributeDecisionSupportMethod">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique"/>
        <owl:definition>A decision-support approach that evaluates and compares alternatives based on multiple criteria or attributes, often involving weighting, scoring, or ranking methods to assist in complex decision processes.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiObjectiveDecisionSupportMethod -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiObjectiveDecisionSupportMethod">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#DecisionSupportTechnique"/>
        <owl:definition>A decision-support approach that involves the simultaneous optimization or evaluation of multiple, often conflicting objectives to identify optimal or balanced solutions.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NGO -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NGO">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Nongovernmental organizations working for example in environmental protection, community development, forest conservation, or advocacy.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NaturalDisturbanceModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <owl:definition>Represents stochastic or deterministic processes such as drought, fire, windthrow, or pest outbreaks.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NonWoodForestProductModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#NonWoodForestProductModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SocioEconomicModel"/>
        <owl:definition>Represents non-wood forest products dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess">
        <owl:definition>A structured approach that actively involves stakeholders, experts, or community members in the design, implementation, or evaluation of a project, model, or decision-support process.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Person -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Person">
        <owl:definition>Describes a human individual who acts as an agent in the context of forest decision support systems. A Person is a biological individual and cannot be decomposed into smaller social units.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#PlanningProblem">
        <owl:definition>Description of the decision-making context that the DSS is designed to address, including its temporal and spatial scales, the type of decision-making situation (e.g., unilateral, participatory, or collegial), the ecosystem services considered, and whether spatial interactions are explicitly represented.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProductivityModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProductivityModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SocioEconomicModel"/>
        <owl:definition>Estimates forest productivity for timber production assessments.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProtectionService -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProtectionService">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <owl:definition>Describes the ecosystem contributions related to the protection, regulation, or maintenance of natural environments, resources, and ecological processes, such as soil conservation, erosion control, or flood regulation.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProvisioningService -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ProvisioningService">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <owl:definition>Describes ecosystem outputs that can be directly consumed, used, or traded — including biomass, water, and other material products.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#RegenerationModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#RegenerationModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
        <owl:definition>Speficies whether the model of vegetation dynamics represents tree regeneration dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#RegulatingService -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#RegulatingService">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <owl:definition>Describes ecosystem contributions that regulate environmental conditions and maintain ecological stability (e.g. climate, air, water, and soil processes).</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ResearchInstitution -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ResearchInstitution">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup"/>
        <owl:definition>Universities, research centers, and scientific organizations conducting studies on forests, ecology, climate, economics, or resource management.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Role -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Role">
        <owl:definition>A Role is a context-dependent, non-physical, realizable entity that a Person (or sometimes an organization) can assume in specific situations, activities, or institutional settings. Roles describe responsibilities, permissions, functions, or positions that are not intrinsic to a person but depend on social, organizational, or procedural context.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Scenario -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Scenario">
        <owl:definition>A structured description of a possible, plausible, or hypothetical state of the world, used to explore future conditions, analyze impacts, support decision-making, or compare alternative developments.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <owl:definition>A forest management strategy that defines how forest stands are established, tended, harvested, and regenerated, based on specific ecological, economic, and operational principles.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalType -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <owl:definition>A category of silvicultural practices that describes the specific type of stand establishment or stand-level treatment applied within a forest management approach.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SnowModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SnowModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SocioEconomicModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SocioEconomicModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Software">
        <owl:definition>The computational component or application implementing the DSS. It includes technical, organizational, and practical information about the information technology aspects of the DSS, covering development background, accessibility, and use conditions.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SoilProcessesModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SoilProcessesModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel"/>
        <owl:definition>Describes nutrient and water cycling dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#TargetUserGroup">
        <owl:definition>A category of individuals or groups for whom a software tool, system, or service is primarily designed or intended to be used.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation">
        <owl:definition>A process or methodological component dedicated to assessing, quantifying, or analyzing uncertainties within a software tool, model, or dataset, including sources of variability, model assumptions, and data limitations.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel"/>
        <owl:definition>Simulates changes in forest composition and structure over time as affected by forest dynamics processes growth, regeneration, and mortality.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WildlifeModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WildlifeModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#EcologicalModel"/>
        <owl:definition>Represents wildlife population dynamics.</owl:definition>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WindModel -->

    <owl:Class rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#WindModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AbioticDisturbanceModel"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AHP -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#AHP">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiAttributeDecisionSupportMethod"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ANP -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ANP">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiAttributeDecisionSupportMethod"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Agroforestry -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Agroforestry">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ArtificialIntelligence -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ArtificialIntelligence">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ArtificialIntelligence"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
        <owl:definition>A knowledge management process that uses computational techniques—such as machine learning, reasoning, perception, and automated decision-making—to acquire, analyze, generate, or apply knowledge.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BayesBeliefsNetwork -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BayesBeliefsNetwork">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BayesBeliefsNetwork"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>A probabilistic graphical model used in uncertainty evaluation that represents variables and their conditional dependencies through a directed acyclic graph, allowing reasoning and inference under uncertainty.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BestPractices -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BestPractices">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#BestPractices"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
        <owl:definition>Typically present the situation, the options, choices taken, and the results for a typical decision problem. Best practices are those attributes ( e.g., structures, disciplines, processes, controls, metrics, tools, and staffing qualifications) demonstrated to be effective guidelines for the successful management of diverse programs and projects. Lessons learned are experiences acquired in the execution of programs and projects which can provided value-added direction to the formulation and execution of future development and operational initiatives. They are widely used in natural resource management and can be extensively found on the internet. &quot;Story telling&quot; allow people to gain more understanding and have greater recall then they do from written reports. Stories can be used to capture lectures on a particular topic, to capture after action reports, to record difficult to codify tacit knowledge, and for many other purposes.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Clear_cut -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Clear_cut">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Close_to_nature_silviculture -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Close_to_nature_silviculture">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Closer_to_nature_silviculture -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Closer_to_nature_silviculture">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#SilviculturalApproach"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CoDesign -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CoDesign">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CoDesign"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ParticipatoryProcess"/>
        <owl:definition>A participatory process in which stakeholders, end users, and developers collaboratively design a system, tool, or solution, ensuring that diverse perspectives and needs are integrated from the earliest stages of development.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CommunityOfPractice -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CommunityOfPractice">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#CommunityOfPractice"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
        <owl:definition>Support groups of individuals with similar work responsibilities but who are not part of a formally designated work team. Many communities of practice communicate through a web-based system.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ConservationManager -->

