    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FuzzySet -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FuzzySet">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#FuzzySet"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#UncertaintyEvaluation"/>
        <owl:definition>A method of uncertainty evaluation based on fuzzy logic, where imprecise or ambiguous information is represented through degrees of membership rather than binary true/false values.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#IntegerPorgamming -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#IntegerPorgamming">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#MultiObjectiveDecisionSupportMethod"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeMap -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeMap">
        <rdf:type rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeMap"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <owl:annotatedTarget rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#KnowledgeManagementProcess"/>
        <owl:definition>Establish a classification scheme called a taxonomy of knowledge, provide a frame of reference for many knowledge management products, and serve as a critical first step for identifying available knowledge. The more sophisticated versions of tools in this category include ontology editors.</owl:definition>
    </owl:Axiom>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#LinearProgramming -->

