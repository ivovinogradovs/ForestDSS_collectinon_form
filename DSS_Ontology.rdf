    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasMixture -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasMixture">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestManagement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <owl:definition>Specifies whether mixed-species forests can be represented.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingMethod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#ForestEcosystemService"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the model or technique used to qunatify or represent the ecosystem service (e.g., Biodiversity = stand structural attributes (e.g., Shannon index, deadwood, habitat trees)</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingTimestep -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingTimestep">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <owl:definition>Specifies the temporal resolution or discrete time interval used in a simulation, model, or forecasting process.</owl:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#hasModelingType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/sheubel/ontologies/2025/9/forestDSS_ontology#VegetationDynamicsModel"/>
